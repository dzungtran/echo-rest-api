{
  "endpoints_acl": {
    "generated-in-routes.json": "will replace at runtime"
  },
  "roles_chart": {
    "owner": {
      "access": ["delete:org", "update:org"]
    },
    "manager": {
      "access": ["invite:org", "create:project", "update:project", "delete:project"],
      "owner": "owner"
    },
    "editor": {
      "access": [],
      "owner": "manager"
    },
    "viewer": {
      "access": [
        "read:org",
        "list:org",

        "list:project",
        "read:project"
      ],
      "owner": "manager"
    },
    "guest": {
      "access": [],
      "owner": "manager"
    }
  }
}
